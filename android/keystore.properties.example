# Bu dosyayi kopyalayip "keystore.properties" olarak kaydedin
# (gercek degerlerle - keystore.properties git'e commitlenmemeli)
storeFile=sakura-release.jks
storePassword=BURAYA_STORE_SIFRESI
keyAlias=sakura
keyPassword=BURAYA_KEY_SIFRESI

