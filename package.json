{
  "name": "alkyone-pos",
  "version": "2.1.0",
  "description": "Alkyone POS - tek kod tabani, tek build; marka adi ilk kurulumda girilir",
  "main": "electron/main.js",
  "scripts": {
    "start": "node scripts/run.js",
    "dev": "node --watch scripts/run.js",
    "electron": "node scripts/set-brand.js alkyone && electron .",
    "build": "node scripts/set-brand.js alkyone && electron-builder -c build/electron-builder.json",
    "build:all": "npm run build",
    "test": "node test/alkyone.test.js",
    "test:api": "node test/api-test.js",
    "test:scenarios": "node test/scenarios.js",
    "test:load": "node test/load-test.js",
    "test:launcher": "node test/launcher.test.js",
    "release": "node scripts/build-release.js"
  },
  "keywords": [
    "pos",
    "restaurant",
    "alkyone"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Alkyonetech/AlkyonePos.git"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^14.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.alkyone.pos",
    "productName": "AlkyonePOS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "public/**/*",
      "data/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data/",
        "to": "data/",
        "filter": [
          "**/*",
          "!orders.json",
          "!reports/**",
          "!backups/**"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Alkyone POS",
      "include": "electron/installer.nsh"
    }
  }
}
